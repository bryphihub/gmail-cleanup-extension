# Dependencies — huge, and can always be regenerated with `npm install`
node_modules/

# OS junk files
.DS_Store

# Editor folders
.vscode/
.idea/

# Private extension signing key — pins this extension's Chrome ID so it stays
# stable no matter where the folder is moved. The public half is safe to keep
# in manifest.json's "key" field; this private half never needs to leave your
# machine unless you're publishing this exact ID to the Chrome Web Store.
extension-private-key.pem

# Local Claude Code tooling config (installed skills, etc.) — not part of
# the extension itself, so it doesn't belong in the repo.
.claude/
